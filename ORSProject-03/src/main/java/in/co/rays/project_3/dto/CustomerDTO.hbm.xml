<?xml version="1.0"?>
<!DOCTYPE hibernate-mapping PUBLIC "-//Hibernate/Hibernate Mapping DTD 3.0//EN"
"http://hibernate.sourceforge.net/hibernate-mapping-3.0.dtd">

<hibernate-mapping package="in.co.rays.project_3.dto">

	<class name="CustomerDTO" table="ST_CUSTOMER">

		<id name="id" type="java.lang.Long">
			<column name="ID"/>
			<generator class="identity"/>
		</id>

		
		<property name="clientName" type="java.lang.String">
			<column name="CLIENT_NAME"/>
		</property>

		<property name="location" type="java.lang.String">
			<column name="LOCATION"/>
		</property>

		<property name="contactNumber" type="java.lang.String">
			<column name="CONTACT_NUMBER"/>
		</property>

		<property name="importance" type="java.lang.String">
			<column name="IMPORTANCE"/>
		</property>

	</class>

</hibernate-mapping>